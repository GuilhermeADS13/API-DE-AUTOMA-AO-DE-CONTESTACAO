# Copie para .env local
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
N8N_WEBHOOK_URL=http://localhost:5678/webhook/contestacao
SESSION_TTL_HOURS=12
SESSION_COOKIE_NAME=contestacao_session
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_SECURE=false

# Opcao 1 (prioritaria): URL completa
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/contestacao_db

# Opcao 2: variaveis separadas (usadas se DATABASE_URL estiver vazio)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=contestacao_db
DATABASE_USER=postgres
DATABASE_PASSWORD=sua_senha_aqui
DATABASE_SSLMODE=prefer
DATABASE_CONNECT_TIMEOUT=5
