# Copie para .env local
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
N8N_WEBHOOK_URL=http://localhost:5678/webhook/contestacao
N8N_WEBHOOK_AUTH_TOKEN=
SESSION_TTL_HOURS=12
SESSION_COOKIE_NAME=contestacao_session
SESSION_COOKIE_SAMESITE=lax
# Em producao com HTTPS, mude para true
SESSION_COOKIE_SECURE=false

# Validacao de Bearer token via Supabase Auth (/auth/v1/user)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
SUPABASE_AUTH_TIMEOUT_SECONDS=8

# --- BANCO DE DADOS (Supabase PostgreSQL) ---
# Use a URL do Transaction Pooler do Supabase para melhor performance
# (Dashboard > Project Settings > Database > Connection string > Transaction pooler)
# Ex: postgresql://postgres.PROJECTREF:SENHA@aws-0-REGION.pooler.supabase.com:6543/postgres
#
# Para conexao direta (sem pooler):
# Ex: postgresql://postgres:SENHA@db.PROJECTREF.supabase.co:5432/postgres
#
# Opcao 1 (prioritaria): URL completa
DATABASE_URL=postgresql://postgres:SUA_SENHA@db.seu-projeto.supabase.co:5432/postgres

# Opcao 2: variaveis separadas (usadas se DATABASE_URL estiver vazio)
DATABASE_HOST=db.seu-projeto.supabase.co
DATABASE_PORT=5432
DATABASE_NAME=postgres
DATABASE_USER=postgres
DATABASE_PASSWORD=sua_senha_aqui
# Supabase exige SSL - nao altere para disable
DATABASE_SSLMODE=require
DATABASE_CONNECT_TIMEOUT=5

# Pool de conexoes com o banco
DATABASE_POOL_MIN=1
DATABASE_POOL_MAX=10

# --- RATE LIMITING ---
# Em producao com multiplos workers, use Redis: redis://localhost:6379
RATE_LIMIT_STORAGE_URI=memory://

# Suporte por e-mail (SMTP)
SUPPORT_SMTP_HOST=smtp.seuprovedor.com
SUPPORT_SMTP_PORT=587
SUPPORT_SMTP_USER=suporte@seudominio.com
SUPPORT_SMTP_PASSWORD=sua_senha_smtp
SUPPORT_SMTP_STARTTLS=true
SUPPORT_SMTP_SSL=false
SUPPORT_SMTP_TIMEOUT_SECONDS=15
SUPPORT_EMAIL_FROM=suporte@seudominio.com
SUPPORT_EMAIL_TO=suporte@seudominio.com
SUPPORT_EMAIL_SUBJECT_PREFIX=[JurisFlow][Suporte]
