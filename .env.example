# ================================================================
# AutoJuri – Variaveis de ambiente para docker-compose (n8n)
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env com chaves reais no repositorio.
# ================================================================

# ── Autenticacao basica do n8n ──────────────────────────────────
N8N_BASIC_AUTH_PASSWORD=troque_esta_senha_segura

# ── Claude / Anthropic (provider principal) ─────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_MAX_TOKENS=4096
# CLAUDE_TEMPERATURE=0.12
# CLAUDE_TIMEOUT_MS=45000

# ── OpenAI (fallback opcional) ──────────────────────────────────
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_MODEL=gpt-4o

# ── Supabase ─────────────────────────────────────────────────────
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxx

# ── PostgreSQL via Supabase pooler ───────────────────────────────
DATABASE_HOST=aws-0-us-west-2.pooler.supabase.com
DATABASE_PORT=6543
DATABASE_NAME=postgres
DATABASE_USER=postgres.SEU_PROJETO_ID
DATABASE_PASSWORD=SUA_SENHA_DO_BANCO
